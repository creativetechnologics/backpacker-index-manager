{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Backpacker Index Wikivoyage Extraction v1",
  "type": "object",
  "required": ["destination", "classification", "content_sections", "quality"],
  "additionalProperties": true,
  "properties": {
    "destination": { "type": "object" },
    "classification": { "type": "object" },
    "content_sections": { "type": "array", "items": { "type": "object" } },
    "practicalities": { "type": "object" },
    "neighborhoods": { "type": "array", "items": { "type": "object" } },
    "payment_methods": { "type": "array", "items": { "type": "object" } },
    "cash_access": { "type": "object" },
    "money_tips": { "type": "array", "items": { "type": "object" } },
    "connectivity_providers": { "type": "array", "items": { "type": "object" } },
    "internet_access": { "type": "array", "items": { "type": "object" } },
    "power_plugs": { "type": "array", "items": { "type": "object" } },
    "language_notes": { "type": "array", "items": { "type": "object" } },
    "religion_culture": { "type": "object" },
    "etiquette_items": { "type": "array", "items": { "type": "object" } },
    "safety_items": { "type": "array", "items": { "type": "object" } },
    "health_risks": { "type": "array", "items": { "type": "object" } },
    "medical_services": { "type": "array", "items": { "type": "object" } },
    "water_safety": { "type": "object" },
    "accessibility": { "type": "object" },
    "legal_notes": { "type": "array", "items": { "type": "object" } },
    "emergency_services": { "type": "array", "items": { "type": "object" } },
    "tourist_information_centers": { "type": "array", "items": { "type": "object" } },
    "permits_fees": { "type": "array", "items": { "type": "object" } },
    "entry_requirements": { "type": "array", "items": { "type": "object" } },
    "driving_rules": { "type": "object" },
    "vehicle_rental_options": { "type": "array", "items": { "type": "object" } },
    "apps": { "type": "array", "items": { "type": "object" } },
    "media_links": { "type": "array", "items": { "type": "object" } },
    "budget_items": { "type": "array", "items": { "type": "object" } },
    "events": { "type": "array", "items": { "type": "object" } },
    "day_trips": { "type": "array", "items": { "type": "object" } },
    "special_interest_details": { "type": "array", "items": { "type": "object" } },
    "work_study_volunteer": { "type": "array", "items": { "type": "object" } },
    "source_snippets": { "type": "array", "items": { "type": "object" } },
    "quality": {
      "type": "object",
      "required": ["overall_confidence", "missing_major_sections", "needs_review_reasons", "do_not_publish_reasons"],
      "additionalProperties": true,
      "properties": {
        "overall_confidence": { "type": ["integer", "null"], "minimum": 1, "maximum": 10 },
        "missing_major_sections": { "type": "array" },
        "needs_review_reasons": { "type": "array" },
        "do_not_publish_reasons": { "type": "array" }
      }
    }
  }
}
